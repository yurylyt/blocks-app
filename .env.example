# ── Required ──────────────────────────────────────────────────────────
# Generate with: openssl rand -base64 32
NUXT_SESSION_PASSWORD=

# Google OAuth (Google Cloud Console → OAuth 2.0 Client ID)
# Authorized redirect URI: https://your-domain.example/auth/google
NUXT_OAUTH_GOOGLE_CLIENT_ID=
NUXT_OAUTH_GOOGLE_CLIENT_SECRET=

# ── Optional ──────────────────────────────────────────────────────────
# PostgreSQL connection string
DATABASE_URL=postgresql://user:password@localhost:5432/blocks

# HTTP server binding (defaults for PM2 in ecosystem.config.cjs)
# HOST=127.0.0.1
# PORT=3000
